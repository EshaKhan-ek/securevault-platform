<group name="securevault">

  <!-- R-01: Brute Force Login Detection -->
  <rule id="100101" level="10" frequency="5" timeframe="120">
   <if_matched_sid>5503</if_matched_sid>
   <same_source_ip />
   <description>SecureVault R-01: Brute force - 5+ login failures in 2 min from same IP</description>
   <group>brute_force,authentication_failures,securevault</group>
   <mitre>
     <id>T1110</id>
   </mitre>
  </rule>

  <!-- R-02: Container Anomaly Detection -->
  <rule id="100102" level="15">
   <if_sid>5503</if_sid>
   <match>container</match>
   <description>SecureVault R-02: Container anomaly detected - suspicious activity</description>
   <group>container_security,falco,securevault</group>
   <mitre>
     <id>T1611</id>
   </mitre>
  </rule>

  <!-- R-03: ML Anomaly + Auth Failure Correlation -->
  <rule id="100103" level="15">
    <match>anomaly_detected</match>
    <description>SecureVault R-03: ML anomaly correlated with auth failures</description>
    <group>ml_anomaly,authentication_failures,securevault</group>
    <mitre>
      <id>T1078</id>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- R-04: Kafka Unauthorized Access -->
  <rule id="100104" level="12">
    <match>AUTHENTICATION_FAILED|AUTHORIZATION</match>
    <description>SecureVault R-04: Kafka ACL bypass detected</description>
    <group>kafka,authentication_failures,securevault</group>
    <mitre>
      <id>T1565</id>
    </mitre>
  </rule>

  <!-- R-05: JWT Manipulation Detection -->
  <rule id="100105" level="12">
    <match>Invalid or expired token</match>
    <description>SecureVault R-05: JWT manipulation detected</description>
    <group>jwt,authentication_failures,securevault</group>
    <mitre>
      <id>T1134</id>
      <id>T1078</id>
    </mitre>
  </rule>

</group>
